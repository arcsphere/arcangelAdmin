# ─────────────────────────────────────────────────────────────────
# ARC 1 Admin Panel — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Admin Access ──────────────────────────────────────────────────
# Comma-separated list of Google emails allowed into the admin panel
# The middleware checks against ADMIN_EMAIL_1 (expand as needed)
ADMIN_EMAIL_1=hrishitababaria08@gmail.com
